# ==============================================
# Tchoucti / Dengoh — Variables d'environnement (Développement)
# ==============================================
# Copier en .env. Ne JAMAIS commiter .env !

# ─── Database ────────────────────────────────
POSTGRES_USER=tchoucti_user
POSTGRES_PASSWORD=tchoucti_dev_password
POSTGRES_DB=tchoucti_db
DATABASE_URL=postgresql+asyncpg://tchoucti_user:tchoucti_dev_password@postgres:5432/tchoucti_db

# ─── Redis ───────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── S3 / MinIO ──────────────────────────────
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin123
S3_BUCKET=tchoucti-files
S3_REGION=us-east-1
S3_PUBLIC_URL=http://localhost:19000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123

# ─── JWT ─────────────────────────────────────
JWT_SECRET_KEY=dev-secret-key-CHANGE-IN-PRODUCTION
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── App ─────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
APP_NAME=Tchoucti
APP_BASE_DOMAIN=localhost
FRONTEND_URL=http://localhost:13000
PLATFORM_ADMIN_SUBDOMAIN=admin

# ─── CORS ────────────────────────────────────
# Liste séparée par virgules. * autorisé en dev.
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://demo.localhost:3000,http://admin.localhost:3000

# ─── Email — dev via Mailpit (catcher SMTP) ──
# UI Mailpit : http://localhost:18025
# En prod : pointer vers un vrai fournisseur (SendGrid, SES, ...).
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@tchoucti.cm
SMTP_FROM_NAME=Tchoucti
SMTP_TLS=false
INVITATION_EXPIRE_DAYS=7

# ─── Ports Docker (host:container) ───────────
POSTGRES_PORT=15432
REDIS_PORT=16379
MINIO_API_PORT=19000
MINIO_CONSOLE_PORT=19001
BACKEND_PORT=18000
FRONTEND_PORT=13000
MAILPIT_SMTP_PORT=11025
MAILPIT_UI_PORT=18025

# ─── Frontend (Next.js public env) ───────────
NEXT_PUBLIC_API_URL=http://localhost:18000/api
NEXT_PUBLIC_ROOT_DOMAIN=localhost

