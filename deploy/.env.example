# Tchoucti — production env template
# Copy to deploy/.env on the VPS and fill in all the secrets.
# Generate strong values for anything tagged CHANGE-ME — never commit the real .env.

# ───────────────────────── Domain ─────────────────────────
# Apex domain; subdomains api.${DOMAIN}, storage.${DOMAIN}, minio.${DOMAIN},
# traefik.${DOMAIN} are all required and must resolve to this VPS.
DOMAIN=myappsuite.com
ACME_EMAIL=ops@myappsuite.com

# ────────────────────── Traefik dashboard ─────────────────
# Basic-auth credentials for https://traefik.${DOMAIN}.
# Generate with: docker run --rm httpd:alpine htpasswd -nbB admin 'CHANGE-ME-PASSWORD'
# IMPORTANT: every "$" must be doubled to "$$" inside this file.
TRAEFIK_AUTH=admin:$$2y$$05$$REPLACE_WITH_HTPASSWD_OUTPUT_WITH_DOUBLED_DOLLARS
TRAEFIK_LOG_LEVEL=INFO

# ──────────────────────── PostgreSQL ──────────────────────
POSTGRES_USER=tchoucti_prod
POSTGRES_PASSWORD=CHANGE-ME-LONG-RANDOM-STRING
POSTGRES_DB=tchoucti

# ─────────────────────────── JWT ──────────────────────────
# 64+ random bytes hex. Generate with:  openssl rand -hex 48
JWT_SECRET_KEY=CHANGE-ME-RUN-openssl-rand-hex-48

# ──────────────────────── MinIO / S3 ──────────────────────
MINIO_ROOT_USER=tchoucti_admin
MINIO_ROOT_PASSWORD=CHANGE-ME-LONG-RANDOM-STRING
S3_BUCKET=tchoucti-files

# ────────────────────────── SMTP ──────────────────────────
# Use a real provider (Brevo / Postmark / SES / Mailgun / OVH).
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_TLS=true
SMTP_USER=apikey-or-username
SMTP_PASSWORD=CHANGE-ME-SMTP-PASSWORD
SMTP_FROM_EMAIL=noreply@myappsuite.com
SMTP_FROM_NAME=Tchoucti
