# Traefik standalone — .env

# Email pour Let's Encrypt (avis d'expiration, etc.)
ACME_EMAIL=ops@example.com

# Host du dashboard (https://${TRAEFIK_HOST}, basic-auth obligatoire)
TRAEFIK_HOST=traefik.example.com

# Basic-auth pour le dashboard.
# Génération :
#   docker run --rm httpd:alpine htpasswd -nbB admin 'MotDePasseFort' \
#     | sed -e 's/\$/\$\$/g'
# IMPORTANT : tous les "$" doivent être doublés en "$$" dans ce fichier.
TRAEFIK_AUTH=admin:$$2y$$05$$REPLACE_WITH_OUTPUT_OF_HTPASSWD

# Verbosité des logs Traefik (DEBUG, INFO, WARN, ERROR)
TRAEFIK_LOG_LEVEL=INFO
